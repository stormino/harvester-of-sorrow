              "mode": "raw",
              "raw": "{\n  \"templateIn\": \"6470a982e4e0301afe1f81f1\",\n  \"templateOut\": \"6516ac5d40da6c377b151642\",\n  \"params\": {\n    \"param\": \"{{search_term}}\",\n    \"from\": 0,\n    \"sort\": \"\",\n    \"size\": 48,\n    \"additionalSize\": 27,\n    \"onlyVideoQuery\": false,\n    \"onlyProgramsQuery\": false\n  }\n}",
