    {
      "name": "👤 Auth",
      "description": "Login, token refresh, user profile.",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.authorization) {",
                  "    pm.environment.set('x_auth_token', json.authorization);",
                  "    console.log('x_auth_token saved');",
                  "}",
                  "if (json.refreshToken) {",
                  "    pm.environment.set('refresh_token', json.refreshToken);",
                  "    console.log('refresh_token saved');",
                  "}",
                  "if (json.ua) {",
                  "    pm.environment.set('ua', json.ua);",
                  "    console.log('ua saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "x-caller",
                "value": "web"
              },
              {
                "key": "Origin",
                "value": "https://www.raiplay.it"
              },
              {
                "key": "Referer",
                "value": "https://www.raiplay.it/"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "domainApiKey",
                  "value": "{{domain_api_key}}",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "{{email}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/atomatic/raisso-service/login/site",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "atomatic",
                "raisso-service",
                "login",
                "site"
              ]
            },
            "description": "Authenticates the user.\n\nResponse fields:\n- `authorization`: JWT token → saved as `x_auth_token`\n- `refreshToken`: refresh token → saved as `refresh_token`\n- `ua`: user agent token → saved as `ua`\n\nThe test script auto-saves all three to environment variables."
          },
          "response": []
        },
        {
          "name": "Token Check (Refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.authorization) {",
                  "    pm.environment.set('x_auth_token', json.authorization);",
                  "    console.log('x_auth_token refreshed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "x-auth-token",
                "value": "{{x_auth_token}}"
              },
              {
                "key": "x-caller",
                "value": "web"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "domainApiKey",
                  "value": "{{domain_api_key}}",
                  "type": "text"
                },
                {
                  "key": "refreshToken",
                  "value": "{{refresh_token}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/atomatic/raisso-service/token/check",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "atomatic",
                "raisso-service",
                "token",
                "check"
              ]
            },
            "description": "Refreshes the JWT using the refreshToken. Test script auto-saves the new `authorization` as `x_auth_token`."
          },
          "response": []
        },
        {
          "name": "User Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-auth-token",
                "value": "{{x_auth_token}}"
              },
              {
                "key": "domainapikey",
                "value": "{{domain_api_key}}"
              },
              {
                "key": "x-caller",
                "value": "web"
              },
              {
                "key": "x-caller-version",
                "value": "1.0"
              }
            ],
            "url": {
              "raw": "{{base_url}}/atomatic/raisso-service/user/infox",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "atomatic",
                "raisso-service",
                "user",
                "infox"
              ]
            },
            "description": "Returns detailed profile info for the authenticated user. Note: `domainapikey` must be lowercase."
          },
          "response": []
        }
      ]
